{
  "name": "agent-flow",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Flow monorepo scaffold based on architecture-design.md",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "pnpm --filter @agent-flow/cli dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "turbo": "^2.5.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
