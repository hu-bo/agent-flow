{
  "name": "@agent-flow/tools-impl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Built-in tool implementations (fs/git/http) for agent-flow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-flow/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
