{
  "name": "@agent-flow/model-adapters-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Native model adapters (OpenAI, Anthropic, Google, DeepSeek)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "import": "./dist/openai/index.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic/index.d.ts",
      "import": "./dist/anthropic/index.js"
    },
    "./google": {
      "types": "./dist/google/index.d.ts",
      "import": "./dist/google/index.js"
    },
    "./deepseek": {
      "types": "./dist/deepseek/index.d.ts",
      "import": "./dist/deepseek/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-flow/core": "workspace:*",
    "openai": "^4.90.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/generative-ai": "^0.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
