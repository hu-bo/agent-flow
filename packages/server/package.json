{
  "name": "@agent-flow/server",
  "version": "0.1.0",
  "private": true,
  "description": "HTTP/WebSocket server for agent-flow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/start.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-flow/core": "workspace:*",
