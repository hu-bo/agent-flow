    "@agent-flow/model-gateway": "workspace:*",
    "@agent-flow/model-adapter-ai-sdk": "workspace:*",
    "@agent-flow/context-store": "workspace:*",
    "@agent-flow/context-compressor": "workspace:*",
    "@agent-flow/checkpoint": "workspace:*",
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/anthropic": "^1.2.0",
    "ai": "^4.3.0",
    "express": "^5.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
