{
  "name": "@agent-flow/chat-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Extensible chat panel component with Markdown, code highlighting, thinking chain, image, diff, and file upload support",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-flow/model-contracts": "workspace:*",
    "diff": "^7.0.0",
    "highlight.js": "^11.11.1",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/diff": "^7.0.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
