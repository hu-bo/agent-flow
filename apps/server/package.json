{
  "name": "@agent-flow/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP/SSE server for agent-flow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/start.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-flow/core": "workspace:*",
    "@agent-flow/model-adapter-ai-sdk": "workspace:*",
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/anthropic": "^1.2.0",
    "@hono/node-server": "^1.13.7",
    "ai": "^4.3.0",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}


