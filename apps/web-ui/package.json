{
  "name": "@agent-flow/web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web interactive playground for agent-flow",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@agent-flow/chat-ui": "workspace:*",
    "@agent-flow/core": "workspace:*",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "less": "^4.4.1",
    "tailwindcss": "4.2.2",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
