{
  "name": "@agent-flow/web-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify-based BFF and API server for agent-flow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@agent-flow/compact": "workspace:*",
    "@agent-flow/core": "workspace:*",
    "@agent-flow/events": "workspace:*",
    "@agent-flow/memory": "workspace:*",
    "@agent-flow/model-adapters": "workspace:*",
    "@agent-flow/tools-impl": "workspace:*",
    "@grpc/grpc-js": "^1.14.1",
    "@grpc/proto-loader": "^0.8.0",
    "@fastify/cors": "^11.1.0",
    "axios": "^1.15.2",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
